GOOGLE_API_KEY=API_KEY_AQUI

# API local de transcripciones (cluster admin facade en Next.js)
TRANSCRIPTION_API_BASE_URL=http://127.0.0.1:3001
TRANSCRIPTION_API_ACCESS_TOKEN=test
TRANSCRIPTION_API_MODEL_PROFILE=balanced-es
TRANSCRIPTION_API_POLL_TIMEOUT_SECONDS=240
TRANSCRIPTION_API_POLL_INTERVAL_SECONDS=3

# Fallback opcional a youtube-transcript-api si el cluster local no responde
STANDUP_ENABLE_YT_TRANSCRIPT_FALLBACK=false
